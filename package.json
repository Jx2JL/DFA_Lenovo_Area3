{
  "name": "trackpoint-notify",
  "version": "1.0.0",
  "description": "TrackPoint coaching — notification-style toast in bottom-right",
  "main": "dist/main.js",
  "scripts": {
    "copy-html": "node -e \"const fs=require('fs'),p=require('path');fs.mkdirSync('dist/renderer',{recursive:true});fs.copyFileSync('src/renderer/index.html','dist/renderer/index.html');\"",
    "build": "tsc && npm run copy-html",
    "start": "npm run build && electron dist/main.js",
    "dev": "npm run build && electron dist/main.js"
  },
  "dependencies": {
    "electron": "^28.0.0",
    "uiohook-napi": "^1.5.4"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "@types/node": "^20.10.0"
  }
}
